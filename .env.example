# Master key that encrypts stored credentials. Generate with: openssl rand -hex 32
VAULTKEEPER_MASTER_KEY=

# Password for the restic repository (BorgBase or any restic backend)
RESTIC_PASSWORD=

# Password for the verify-postgres scratch database (compose verify profile).
# Must be URL-safe or percent-encoded (e.g. p@ss/word -> p%40ss%2Fword): it is interpolated into [verify] postgres_url.
VERIFY_PG_PASSWORD=

# Optional overrides
# VAULTKEEPER_CONFIG=/config/config.toml
# VAULTKEEPER_DB=/data/vaultkeeper.db
# Maximum time Compose lets an in-flight backup/restore finish after SIGTERM.
# Keep this above the combined source/restic deadlines configured for one run.
# VAULTKEEPER_STOP_GRACE_PERIOD=14h10m
